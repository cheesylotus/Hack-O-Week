<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Final Boss Store</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: linear-gradient(120deg, #141e30, #243b55);
    color: white;
}

/* NAVBAR */
nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 30px;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 1000;
}

nav h1 {
    font-size: 1.5rem;
}

.search-box {
    padding: 8px 15px;
    border-radius: 20px;
    border: none;
    width: 250px;
}

/* CART */
.cart {
    position: relative;
    font-size: 1.5rem;
}

.cart span {
    position: absolute;
    top: -8px;
    right: -10px;
    background: red;
    font-size: 0.7rem;
    padding: 3px 6px;
    border-radius: 50%;
}

/* LAYOUT */
.container {
    display: flex;
}

/* SIDEBAR */
.sidebar {
    width: 220px;
    padding: 20px;
    background: rgba(255,255,255,0.05);
}

.sidebar h3 {
    margin-bottom: 10px;
}

.sidebar li {
    list-style: none;
    margin: 8px 0;
    cursor: pointer;
}

.sidebar li:hover {
    color: #00c6ff;
}

/* PRODUCTS GRID */
.products {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 20px;
    padding: 20px;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.05);
    border-radius: 15px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    position: relative;
    transition: 0.4s;
}

.card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.6);
}

/* IMAGE */
.card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

/* BADGE */
.badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #ff4d4d;
    padding: 5px;
    border-radius: 5px;
    font-size: 0.8rem;
}

/* WISHLIST */
.wishlist {
    position: absolute;
    top: 10px;
    right: 10px;
    cursor: pointer;
    transition: 0.3s;
}

.wishlist:hover {
    color: red;
    transform: scale(1.2);
}

/* CONTENT */
.content {
    padding: 15px;
}

.tag {
    font-size: 0.8rem;
    color: #00c6ff;
}

.rating {
    color: gold;
    font-size: 0.9rem;
    margin: 5px 0;
}

.price {
    color: #00ffcc;
}

.old {
    text-decoration: line-through;
    font-size: 0.8rem;
    color: #aaa;
}

/* BUTTON */
.btn {
    display: block;
    text-align: center;
    margin-top: 10px;
    padding: 8px;
    background: linear-gradient(45deg, #00c6ff, #0072ff);
    border-radius: 20px;
    color: white;
    text-decoration: none;
    transition: 0.3s;
}

.btn:hover {
    transform: scale(1.05);
}

/* FOOTER */
footer {
    text-align: center;
    padding: 15px;
    color: #ccc;
}

/* RESPONSIVE */
@media(max-width: 800px) {
    .container {
        flex-direction: column;
    }
    .sidebar {
        width: 100%;
    }
}
</style>
</head>

