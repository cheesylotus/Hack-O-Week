<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tasty Bites | Hotel Menu</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  scroll-behavior:smooth;
}

body{
  font-family:'Poppins',sans-serif;
  background:#fdfdfd;
  color:#333;
}

/* NAVBAR */
nav{
  position:fixed;
  width:100%;
  top:0;
  background:rgba(0,0,0,0.8);
  padding:15px 50px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  z-index:1000;
}

nav h2{
  color:#fff;
  font-family:'Playfair Display',serif;
}

nav ul{
  list-style:none;
  display:flex;
  gap:25px;
}

nav ul li a{
  text-decoration:none;
  color:#fff;
  font-weight:500;
  transition:0.3s;
}

nav ul li a:hover{
  color:#e63946;
}

/* HERO */
header{
  height:90vh;
  background:linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),
  url("https://images.unsplash.com/photo-1504674900247-0877df9cc836") center/cover no-repeat;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  color:#fff;
  padding-top:60px;
}

header h1{
  font-family:'Playfair Display',serif;
  font-size:3.5rem;
}

header p{
  margin-top:15px;
  font-size:1.2rem;
  opacity:0.9;
}

/* SECTION TITLE */
.menu-title{
  text-align:center;
  margin:80px 0 40px;
}

.menu-title h2{
  font-size:2.5rem;
  color:#e63946;
  font-family:'Playfair Display',serif;
}

/* MENU GRID */
.menu{
  width:90%;
  max-width:1200px;
  margin:auto;
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:30px;
}

/* CARD */
.card{
  background:#fff;
  border-radius:20px;
  overflow:hidden;
  box-shadow:0 15px 30px rgba(0,0,0,0.1);
  transition:0.4s;
  position:relative;
}

.card:hover{
  transform:translateY(-12px);
  box-shadow:0 20px 40px rgba(0,0,0,0.2);
}

.card img{
  width:100%;
  height:220px;
  object-fit:cover;
  transition:0.4s;
}

.card:hover img{
  transform:scale(1.1);
}

/* BADGE */
.badge{
  position:absolute;
  top:15px;
  left:15px;
  background:#e63946;
  color:#fff;
  padding:5px 12px;
  border-radius:20px;
  font-size:0.8rem;
}

/* CARD CONTENT */
.card-content{
  padding:20px;
}

.card-content h3{
  margin-bottom:10px;
}

.card-content p{
  font-size:0.9rem;
  color:#666;
}

/* RATING */
.rating{
  margin:10px 0;
  color:gold;
  font-size:0.9rem;
}

/* FOOTER CARD */
.card-footer{
  margin-top:15px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.price{
  font-weight:700;
  font-size:1.1rem;
  color:#e63946;
}

/* BUTTON */
button{
  background:#e63946;
  border:none;
  color:#fff;
  padding:8px 18px;
  border-radius:25px;
  cursor:pointer;
  transition:0.3s;
}

button:hover{
  background:#1d3557;
  transform:scale(1.05);
}

/* FOOTER */
footer{
  margin-top:80px;
  padding:30px;
  text-align:center;
  background:#111;
  color:#fff;
}
</style>
</head>

<body>

<!-- NAVBAR -->
<nav>
  <h2>Tasty Bites</h2>
  <ul>
    <li><a href="#">Home</a></li>
    <li><a href="#">Menu</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<header>
  <div>
    <h1>Welcome to Tasty Bites</h1>
    <p>Luxury Dining Experience • Fresh & Authentic</p>
  </div>
</header>

<!-- MENU TITLE -->
<section class="menu-title">
  <h2>Chef's Special Menu</h2>
</section>

<!-- MENU -->
<section class="menu">

  <div class="card">
    <span class="badge">Popular</span>
    <img src="https://images.unsplash.com/photo-1606755962773-d324e0a13086">
    <div class="card-content">
      <h3>Classic Burger</h3>
      <p>Juicy beef patty with cheddar cheese and organic vegetables.</p>
      <div class="rating">★★★★★</div>
      <div class="card-footer">
        <span class="price">$8.99</span>
        <button>Order Now</button>
      </div>
    </div>
  </div>

  <div class="card">
    <span class="badge">Chef Choice</span>
    <img src="https://images.unsplash.com/photo-1601924582975-7fbbfbc9c7f2">
    <div class="card-content">
      <h3>Cheese Pizza</h3>
      <p>Stone baked pizza topped with premium mozzarella cheese.</p>
      <div class="rating">★★★★★</div>
      <div class="card-footer">
        <span class="price">$10.99</span>
        <button>Order Now</button>
      </div>
    </div>
  </div>

  <div class="card">
    <img src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe">
    <div class="card-content">
      <h3>Pasta Alfredo</h3>
      <p>Creamy Alfredo sauce blended with Italian herbs & parmesan.</p>
      <div class="rating">★★★★☆</div>
      <div class="card-footer">
        <span class="price">$9.99</span>
        <button>Order Now</button>
      </div>
    </div>
  </div>

</section>

<footer>
  © 2026 Tasty Bites Hotel | Designed with ❤️
</footer>

</body>
</html>
