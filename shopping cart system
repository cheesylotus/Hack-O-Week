<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌸 Blooming Flowers Shop 🌸</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI', sans-serif;}
body { background: linear-gradient(120deg, #fff0f5, #fff7f0); }
h1 { text-align:center; color:#e91e63; margin:20px 0; font-size:2.5rem; text-shadow:2px 2px #ffe6f0; }

/* Container & Catalogue */
.container { max-width:1200px; margin:auto; padding:20px; }
.catalogue { display:flex; flex-wrap:wrap; justify-content:center; gap:20px; }

/* Flower Card */
.flower-card {
    background:white;
    width:220px;
    border-radius:25px;
    box-shadow:0 10px 30px rgba(233,30,99,0.2);
    text-align:center;
    padding:15px;
    transition:0.4s;
    position:relative;
}
.flower-card::before{
    content:"🌸";
    position:absolute;
    top:-10px; left:-10px; font-size:2rem; opacity:0.2;
}
.flower-card:hover {
    transform:translateY(-10px) rotate(-1deg);
    box-shadow:0 20px 35px rgba(233,30,99,0.3);
}
.flower-card img {
    width:100%;
    height:200px;
    object-fit:cover;
    border-radius:15px;
    margin-bottom:10px;
}
.flower-card h3 { margin-bottom:5px; color:#333; font-size:1.1rem; }
.flower-card p { margin-bottom:10px; color:#555; font-weight:bold; }
.flower-card button {
    padding:10px 15px;
    border:none;
    border-radius:50px;
    background:#e91e63;
    color:white;
    cursor:pointer;
    font-weight:bold;
    margin:5px 0;
    transition:0.3s;
}
.flower-card button:hover { background:#c2185b; transform:scale(1.1) rotate(-1deg); }

/* Cart Panel */
.cart { position:fixed; top:0; right:0; width:350px; height:100%; background:#fff0f5; box-shadow:-5px 0 25px rgba(0,0,0,0.2); transform:translateX(100%); transition:0.5s; padding:20px; overflow-y:auto; z-index:1000; border-left:5px solid #e91e63; }
.cart.show { transform:translateX(0); }
.cart h2 { margin-bottom:20px; color:#e91e63; text-align:center; text-shadow:1px 1px #ffe6f0; }
.cart-item { display:flex; align-items:center; justify-content:space-between; background:#fff7f7; margin-bottom:15px; padding:10px; border-radius:15px; box-shadow:0 4px 15px rgba(233,30,99,0.1); }
.cart-item img { width:50px; height:50px; object-fit:cover; border-radius:10px; margin-right:10px; }
.cart-item-info { flex:1; }
.cart-item-info h4 { font-size:0.9rem; margin-bottom:5px; color:#333; }
.cart-item-info p { font-size:0.8rem; color:#555; margin-bottom:5px; }
.cart-item-info input { width:50px; padding:5px; text-align:center; margin-right:5px; border-radius:5px; border:1px solid #ccc; }
.cart-item button { padding:5px 8px; border:none; border-radius:50px; background:#e91e63; color:white; cursor:pointer; margin-left:5px; font-size:0.8rem; transition:0.3s; }
.cart-item button:hover { background:#c2185b; transform:scale(1.05); }

/* Cart Footer */
.cart-footer { margin-top:20px; border-top:2px dashed #e91e63; padding-top:15px; }
.cart-footer p { font-weight:bold; margin:5px 0; text-align:right; color:#333; }
.cart-footer button { width:100%; padding:12px; border:none; border-radius:50px; background:#4caf50; color:white; font-weight:bold; cursor:pointer; margin-top:10px; transition:0.3s; }
.cart-footer button:hover { background:#388e3c; transform:scale(1.05); }

/* Cart Toggle */
.cart-toggle { position:fixed; top:20px; right:20px; background:#e91e63; color:white; padding:15px 20px; border-radius:50px; cursor:pointer; box-shadow:0 5px 15px rgba(0,0,0,0.2); z-index:1001; transition:0.3s; }
.cart-toggle:hover { background:#c2185b; transform:scale(1.1); }

/* Notification */
.notification {
    position:fixed;
    top:80px;
    right:30px;
    background:#4caf50;
    color:white;
    padding:10px 20px;
    border-radius:50px;
    box-shadow:0 5px 15px rgba(0,0,0,0.2);
    opacity:0;
    transition:0.5s;
    z-index:2000;
}

/* Empty cart */
.empty { text-align:center; color:#999; font-style:italic; padding:20px 0; }

@media(max-width:768px){
    .catalogue { flex-direction:column; align-items:center; }
    .cart { width:80%; }
}
</style>
</head>
<body>

<h1>🌸 Blooming Flowers Shop 🌸</h1>
<div class="container">
    <div class="catalogue" id="flowerCatalogue"></div>
</div>

<!-- Cart Panel -->
<div class="cart" id="cartPanel">
    <h2>Your Cart</h2>
    <div id="cartItems">
        <p class="empty">Your cart is empty</p>
    </div>
    <div class="cart-footer" id="cartFooter">
        <p>Shipping: $5</p>
        <p>Total: $0</p>
        <button onclick="checkout()">Checkout</button>
    </div>
</div>

<div class="cart-toggle" onclick="toggleCart()">🛒 Cart</div>
<div class="notification" id="notification">Added to Cart!</div>

<script>
// Flowers data with reliable images
const flowers = [
    {id:1, name:"Red Roses", price:10, img:"https://images.unsplash.com/photo-1601758123927-1e8faebfca70?auto=format&fit=crop&w=400&q=80"},
    {id:2, name:"Sunflowers", price:8, img:"https://images.unsplash.com/photo-1528825871115-3581a5387919?auto=format&fit=crop&w=400&q=80"},
    {id:3, name:"Tulips", price:12, img:"https://images.unsplash.com/photo-1528821154947-41a16756f5ed?auto=format&fit=crop&w=400&q=80"},
    {id:4, name:"Lilies", price:15, img:"https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=400&q=80"},
    {id:5, name:"Daisies", price:7, img:"https://images.unsplash.com/photo-1501004318640-88e9b7d9d6b7?auto=format&fit=crop&w=400&q=80"},
    {id:6, name:"Orchids", price:20, img:"https://images.unsplash.com/photo-1523292485202-848a1bb73c31?auto=format&fit=crop&w=400&q=80"},
    {id:7, name:"Peonies", price:18, img:"https://images.unsplash.com/photo-1501004318642-4f6b3a19d5e2?auto=format&fit=crop&w=400&q=80"},
    {id:8, name:"Carnations", price:9, img:"https://images.unsplash.com/photo-1523292485203-521b5df07a42?auto=format&fit=crop&w=400&q=80"},
    {id:9, name:"Lavender", price:11, img:"https://images.unsplash.com/photo-1523292485201-7f1b01c91f32?auto=format&fit=crop&w=400&q=80"},
    {id:10, name:"Hydrangeas", price:14, img:"https://images.unsplash.com/photo-1523292485200-31ff82401b6e?auto=format&fit=crop&w=400&q=80"}
];

// Linked List
class Node { constructor(data){ this.data=data; this.next=null; } }
class LinkedList{
    constructor(){ this.head=null; }
    append(data){
        const newNode=new Node(data);
        if(!this.head){ newNode.data.qty=1; this.head=newNode; }
        else {
            let curr=this.head;
            while(curr.next){
                if(curr.data.id===data.id){ curr.data.qty+=1; return; }
                curr=curr.next;
            }
            if(curr.data.id===data.id){ curr.data.qty+=1; return; }
            newNode.data.qty=1;
            curr.next=newNode;
        }
    }
    remove(id){
        if(!this.head) return;
        if(this.head.data.id===id){ this.head=this.head.next; return; }
        let curr=this.head;
        while(curr.next && curr.next.data.id!==id) curr=curr.next;
        if(curr.next && curr.next.data.id===id) curr.next=curr.next.next;
    }
    toArray(){ const arr=[]; let curr=this.head; while(curr){ arr.push(curr.data); curr=curr.next; } return arr; }
}

const cart = new LinkedList();
const shippingCost = 5;

// Render Flowers
function renderFlowers(){
    const grid=document.getElementById("flowerCatalogue");
    grid.innerHTML="";
    flowers.forEach(flower=>{
        const card=document.createElement("div");
        card.className="flower-card";
        card.innerHTML=`
            <img src="${flower.img}" alt="${flower.name}">
            <h3>${flower.name}</h3>
            <p>$${flower.price}</p>
            <button onclick="addToCart(${flower.id})">Add to Cart</button>
            <button onclick="buyNow(${flower.id})">Buy Now</button>
        `;
        grid.appendChild(card);
    });
}

// Add to Cart
function addToCart(id){
    const flower=flowers.find(f=>f.id===id);
    cart.append(flower);
    renderCart();
    showNotification(`${flower.name} added to cart!`);
}

// Buy Now
function buyNow(id){
    const flower=flowers.find(f=>f.id===id);
    alert(`✅ You bought ${flower.name} for $${flower.price}`);
}

// Render Cart
function renderCart(){
    const container=document.getElementById("cartItems");
    container.innerHTML="";
    const items=cart.toArray();
    if(items.length===0){
        container.innerHTML='<p class="empty">Your cart is empty</p>';
        updateTotal(0);
        return;
    }
    let subtotal=0;
    items.forEach(item=>{
        subtotal += item.price * item.qty;
        const div=document.createElement("div");
        div.className="cart-item";
        div.innerHTML=`
            <img src="${item.img}" alt="${item.name}">
            <div class="cart-item-info">
                <h4>${item.name}</h4>
                <p>$${item.price} x <input type="number" value="${item.qty}" min="1" onchange="updateQty(${item.id}, this.value)"></p>
            </div>
            <button onclick="removeFromCart(${item.id})">Remove</button>
            <button onclick="buyNow(${item.id})">Buy Now</button>
        `;
        container.appendChild(div);
    });
    updateTotal(subtotal);
}

function updateQty(id, qty){
    const items=cart.toArray();
    for(let item of items){
        if(item.id===id){
            item.qty=parseInt(qty);
            break;
        }
    }
    renderCart();
}

// Remove
function removeFromCart(id){
    cart.remove(id);
    renderCart();
}

// Update total
function updateTotal(subtotal){
    const totalElem=document.querySelector(".cart-footer p:nth-child(2)");
    totalElem.textContent = `Total: $${subtotal + (subtotal>0 ? shippingCost : 0)}`;
}

// Checkout
function checkout(){
    const items=cart.toArray();
    if(items.length===0){ alert("Cart is empty!"); return; }
    alert("✅ Checkout successful!\nTotal: $" + (items.reduce((sum,i)=>sum+i.price*i.qty,0)+shippingCost));
    cart.head=null;
    renderCart();
}

// Toggle Cart
function toggleCart(){ document.getElementById("cartPanel").classList.toggle("show"); }

// Notification
function showNotification(message){
    const notif=document.getElementById("notification");
    notif.textContent=message;
    notif.style.opacity=1;
    setTimeout(()=>{ notif.style.opacity=0; },1500);
}

// Initial
renderFlowers();
renderCart();
</script>
</body>
</html>
